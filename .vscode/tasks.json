{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/FileDeduplicator/FileDeduplicator.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "run FindDuplicatesCommand",
			"type": "shell",
			"command": "dotnet run --project FileDeduplicator/FileDeduplicator.csproj find-duplicates --path FileDeduplicator.Tests/test_files",
			"args": [],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "run FindDuplicatesCommand (pwsh)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"FileDeduplicator/FileDeduplicator.csproj",
				"find-duplicates",
				"--path",
				"FileDeduplicator.Tests/test_files"
			],
			"options": {
				"shell": {
					"executable": "pwsh",
					"args": ["-Command"]
				}
			},
			"group": "build"
		},
		{
			"label": "publish (select platform)",
			"type": "process",
			"command": "dotnet",
			"args": ["publish", "${workspaceFolder}/FileDeduplicator/FileDeduplicator.csproj", "-c", "Release", "-r", "${input:rid}"],
			"group": "build"
		},
		{
			"label": "publish all platforms",
			"type": "shell",
			"command": "for rid in osx-arm64 osx-x64 linux-x64 linux-arm64 win-x64; do dotnet publish ${workspaceFolder}/FileDeduplicator/FileDeduplicator.csproj -c Release -r $rid || exit 1; done",
			"group": "build",
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "rid",
			"type": "pickString",
			"description": "Select target Runtime Identifier",
			"options": ["osx-arm64", "osx-x64", "linux-x64", "linux-arm64", "win-x64"],
			"default": "osx-arm64"
		}
	]
}