{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/FileDeduplicator/FileDeduplicator.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "run FindDuplicatesCommand",
			"type": "shell",
			"command": "dotnet run --project FileDeduplicator/FileDeduplicator.csproj find-duplicates --path FileDeduplicator.Tests/test_files",
			"args": [],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "run FindDuplicatesCommand (pwsh)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"FileDeduplicator/FileDeduplicator.csproj",
				"find-duplicates",
				"--path",
				"FileDeduplicator.Tests/test_files"
			],
			"options": {
				"shell": {
					"executable": "pwsh",
					"args": ["-Command"]
				}
			},
			"group": "build"
		}
	]
}